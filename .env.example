# ==============================================================================
# DATABASE SETTINGS
# ==============================================================================
# Requirements: Minimum 8 characters. Must include 3 of the following 4 groups:
# uppercase, lowercase, base 10 digits and symbols (e.g. ! # $ %).
# Example: YourStrongPassword123!
# [REQUIRED]
MSSQL_SA_PASSWORD=

# ==============================================================================
# JWT SETTINGS
# ==============================================================================
# Requirements: For HS256, the key MUST be at least 256-bit (32 characters).
# Best Practice: Use a cryptographically random string of 64+ characters to
# ensure maximum entropy and resistance to brute-force attacks.
# Tip: Generate a secure key using: openssl rand -base64 48
# Example: at_least_32_chars_long_random_string_here_64_is_better_123456
# [REQUIRED]
JWT_KEY=

# ==============================================================================
# ZAP SCANNER SETTINGS
# ==============================================================================
# [REQUIRED]
ZAP_VERSION=2.17.0

# ZAP_MODE defines the safety guardrails for the scanner.
# Available values:
#   - safe:      No potentially dangerous operations permitted (passive scan only).
#   - protected: Dangerous actions only allowed on URLs defined in the Scope.
#   - standard:  The default mode; allows all operations but doesn't auto-attack.
#   - attack:    Most aggressive; automatically scans/attacks new URLs as discovered.
#
# NOTE: The current C# implementation uses the '-quickurl' argument, which 
# forces 'attack' behavior regardless of the mode set here.
ZAP_MODE=attack